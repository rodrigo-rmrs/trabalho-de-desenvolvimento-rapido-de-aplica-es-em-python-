        if texto is None:
            return
        texto = texto.lower()
        vogais = 0
        consoantes = 0
        for letra in texto:
            if letra.isalpha():
                if letra in "aeiou":
                    vogais += 1
                else:
                    consoantes += 1
        self.escrever("Vogais: " + str(vogais))
        self.escrever("Consoantes: " + str(consoantes))

    def ex14(self):
        texto = self.pedir_texto("Inverter Case", "Digite um texto:")
        if texto is None:
            return
        resultado = ""
        for letra in texto:
            if letra.isupper():
                resultado += letra.lower()
            elif letra.islower():
                resultado += letra.upper()
            else:
                resultado += letra
        self.escrever(resultado)

