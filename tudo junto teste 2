    def escrever(self, texto):
        self.saida.insert(END, str(texto) + "\n")
        self.saida.see(END)

    def limpar_saida(self):
        self.saida.delete("1.0", END)

    def executar(self, numero):
        self.limpar_saida()
        self.escrever(f"Executando exercício {numero}: {self.nomes[numero]}")
        self.escrever("-" * 60)
        try:
            self.funcoes[numero]()
        except Exception as erro:
            self.escrever("Erro: " + str(erro))

    def mostrar_grupo(self, inicio, fim):
        for widget in self.botoes.winfo_children():
            widget.destroy()

        self.titulo["text"] = f"Exercícios {inicio} a {fim}"

        linha = 0
        coluna = 0

        for numero in range(inicio, fim + 1):
            Button(
                self.botoes,
                text=f"{numero} - {self.nomes[numero]}",
                width=30,
                height=2,
                command=lambda n=numero: self.executar(n)
            ).grid(row=linha, column=coluna, padx=5, pady=5)

            coluna += 1
            if coluna == 2:
                coluna = 0
                linha += 1

