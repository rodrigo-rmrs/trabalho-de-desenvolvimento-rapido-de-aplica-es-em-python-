import psycopg2

try:
    conexao = psycopg2.connect(
        host="localhost",
        database="teste",
        user="postgres",
        password="1234"
    )
    cursor = conexao.cursor()
    cursor.execute("""
    UPDATE contas_bancarias
    SET saldo = saldo - 100
    WHERE id = 1
    """)
    cursor.execute("""
    UPDATE contas_bancarias
    SET saldo = saldo + 100
    WHERE id = 2
    """)
    conexao.commit()
    print("Transferência realizada com sucesso.")
except Exception as erro:
    conexao.rollback()
    print("Erro na transferência:", erro)
finally:
    conexao.close()
