def ex43():
    janela = Tk()
    janela.title("Mini ERP")
    janela.geometry("500x400")
    con = sqlite3.connect("estoque.db")
    cur = con.cursor()
    cur.execute("CREATE TABLE IF NOT EXISTS produtos (id INTEGER PRIMARY KEY AUTOINCREMENT, nome TEXT, preco REAL)")
    Label(janela, text="Nome").pack()
    nome = Entry(janela)
    nome.pack()
    Label(janela, text="Preço").pack()
    preco = Entry(janela)
    preco.pack()
    lista = Listbox(janela, width=50)
    lista.pack(pady=10)

    def listar():
        lista.delete(0, END)
        cur.execute("SELECT * FROM produtos")
        for p in cur.fetchall():
            lista.insert(END, f"{p[0]} - {p[1]} - R$ {p[2]:.2f}")

    def cadastrar():
        try:
            cur.execute("INSERT INTO produtos (nome, preco) VALUES (?, ?)", (nome.get(), float(preco.get())))
            con.commit()
            listar()
        except:
            messagebox.showerror("Erro", "Dados inválidos.")

    def deletar():
        try:
            selecionado = lista.get(lista.curselection())
            id_prod = selecionado.split(" - ")[0]
            cur.execute("DELETE FROM produtos WHERE id=?", (id_prod,))
            con.commit()
            listar()
        except:
            messagebox.showerror("Erro", "Selecione um produto.")

    Button(janela, text="Cadastrar", command=cadastrar).pack()
    Button(janela, text="Listar", command=listar).pack()
    Button(janela, text="Deletar", command=deletar).pack()
    listar()
    janela.mainloop()
    con.close()


