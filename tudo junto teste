def ex48():
    janela = Tk()
    janela.title("Login")
    janela.geometry("350x250")
    con = sqlite3.connect("login.db")
    cur = con.cursor()
    cur.execute("CREATE TABLE IF NOT EXISTS usuarios (id INTEGER PRIMARY KEY AUTOINCREMENT, email TEXT UNIQUE, senha TEXT)")
    senha_padrao = hashlib.sha256("1234".encode()).hexdigest()
    try:
        cur.execute("INSERT INTO usuarios (email, senha) VALUES (?, ?)", ("admin@gmail.com", senha_padrao))
        con.commit()
    except sqlite3.IntegrityError:
        pass

    def salvar_log(email, resultado):
        with open("auditoria.log", "a", encoding="utf-8") as f:
            f.write(f"{datetime.now().strftime('%d/%m/%Y %H:%M:%S')} - {email} - {resultado}\n")

    Label(janela, text="E-mail").pack()
    email = Entry(janela, width=30)
    email.pack()
    Label(janela, text="Senha").pack()
    senha = Entry(janela, show="*", width=30)
    senha.pack()

    def login():
        if not re.match(r"^[\w\.-]+@[\w\.-]+\.\w+$", email.get()):
            salvar_log(email.get(), "EMAIL INVALIDO")
            messagebox.showerror("Erro", "E-mail inválido.")
            return
        senha_hash = hashlib.sha256(senha.get().encode()).hexdigest()
        cur.execute("SELECT * FROM usuarios WHERE email=? AND senha=?", (email.get(), senha_hash))
        if cur.fetchone():
            salvar_log(email.get(), "SUCESSO")
            messagebox.showinfo("Sucesso", "Login realizado.")
        else:
            salvar_log(email.get(), "FALHA")
            messagebox.showerror("Erro", "E-mail ou senha incorretos.")

    Button(janela, text="Entrar", command=login).pack(pady=15)
    janela.mainloop()
    con.close()


