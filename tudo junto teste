# 39 a 50
def ex39():
    with open("cadastros_sujos.txt", "r", encoding="utf-8") as arquivo:
        linhas = arquivo.readlines()
    with open("clientes_limpos.csv", "w", newline="", encoding="utf-8") as csvfile:
        escritor = csv.writer(csvfile)
        escritor.writerow(["Nome", "Email", "Telefone"])
        for linha in linhas:
            try:
                email = re.search(r"[\w\.-]+@[\w\.-]+\.\w+", linha)
                telefone = re.search(r"\(\d{2}\)\s\d{5}-\d{4}", linha)
                if not email or not telefone:
                    raise ValueError
                nome = linha.replace(email.group(), "").replace(telefone.group(), "")
                nome = " ".join(nome.split())
                escritor.writerow([nome, email.group(), telefone.group()])
            except:
                print("Linha inválida:", linha.strip())
    print("clientes_limpos.csv criado.")


def ex40():
    janela = Tk()
    janela.title("Cadastro")
    janela.geometry("350x300")
    con = sqlite3.connect("usuarios_cadastro.db")
    cur = con.cursor()
    cur.execute("CREATE TABLE IF NOT EXISTS usuarios (id INTEGER PRIMARY KEY AUTOINCREMENT, nome TEXT, email TEXT, cpf TEXT UNIQUE)")
