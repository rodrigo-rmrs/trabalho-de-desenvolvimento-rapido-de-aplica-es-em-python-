import re

def contar_letras(texto):
    texto = texto.lower()
    vogais = 0
    consoantes = 0
    for letra in texto:
        if letra.isalpha():
            if letra in "aeiou":
                vogais += 1
            else:
                consoantes += 1
    print("Vogais:", vogais)
    print("Consoantes:", consoantes)
frase = input("Digite uma frase: ")

contar_letras(frase)
