import re

with open("datas.txt", "r", encoding="utf-8") as arquivo:
    texto = arquivo.read()

padrao1 = r"(\d{2})/(\d{2})/(\d{4})"
padrao2 = r"(\d{4})-(\d{2})-(\d{2})"

texto = re.sub(padrao1, r"\1-\2-\3", texto)

texto = re.sub(padrao2, r"\3-\2-\1", texto)

with open("datas_formatadas.txt", "w", encoding="utf-8") as novo:
    novo.write(texto)

print("Datas formatadas com sucesso.")
